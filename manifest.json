{
  "manifest_version": 3,
  "name": "Better Tarefario",
  "version": "1.0.0",
  "description": "Organiza cards e integra transferencia dos apontamentos para o site de ponto.",
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://tarefario.dtigab.com.br/*",
    "http://ponto4psg.aguiabranca.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tarefario.dtigab.com.br/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}